{
  "name": "edt",
  "version": "0.1.0",
  "description": "Enterprise Deployment Toolkit - A professional Windows desktop toolbox for enterprise software implementation engineers",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.web.config.ts --port 5173",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --win",
    "package:portable": "electron-vite build && electron-builder --win portable",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "keywords": [
    "enterprise",
    "deployment",
    "toolkit",
    "devops"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@electron/rebuild": "^4.0.6",
    "@types/crypto-js": "^4.2.2",
    "@types/diff": "^7.0.2",
    "@types/node": "^26.0.1",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.2",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.6.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^6.4.3"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@monaco-editor/react": "^4.7.0",
    "@types/pdfjs-dist": "^2.10.377",
    "antd": "^5.29.3",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "diff": "^9.0.0",
    "docx": "^9.7.1",
    "js-yaml": "^5.2.0",
    "jwt-decode": "^4.0.0",
    "nanoid": "^5.1.16",
    "papaparse": "^5.5.4",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "sql-formatter": "^15.8.2",
